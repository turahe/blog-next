# Copy to `.env.local` and adjust. Next.js loads `.env.local` for local dev (gitignored).
# https://nextjs.org/docs/app/guides/environment-variables

# --- Public (exposed to the browser; must be prefixed with NEXT_PUBLIC_) ---

# Backend API base URL (posts, tags, auth). Default in code: http://localhost:8080/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# Canonical site URL for metadata, Open Graph, and absolute links. Default: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional — shown in contact CTAs (see lib/site-metadata.ts)
# NEXT_PUBLIC_CONTACT_EMAIL=

# Optional — override default about portrait on the homepage (default: /images/about-portrait.svg)
# NEXT_PUBLIC_PROFILE_IMAGE=/images/about-portrait.svg
